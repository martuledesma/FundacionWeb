rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo el admin puede escribir en siteContent
    match /siteContent/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'martinaledesma2@gmail.com';
    }

    // Reglas por defecto para otros documentos
    match /{document=**} {
      allow read, write: if false;
    }
  }
}