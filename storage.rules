rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Solo el admin puede subir imágenes a la carpeta cards
    match /cards/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'martinaledesma2@gmail.com';
    }

    // Reglas por defecto para otros archivos
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}